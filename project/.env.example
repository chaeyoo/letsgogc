# 이 파일을 .env 로 복사하거나 아래 값을 환경변수로 export 하세요.
# 아무 것도 설정하지 않아도 '오프라인 모드'로 데모가 동작합니다.

# --- LLM 모드 (선택) ---
# Enterprise LLM API 키를 넣으면 에이전트가 실제 Claude tool-use 루프로 동작합니다.
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8

# --- RAG 하이퍼파라미터 (선택, 기본값 있음) ---
# CHUNK_SIZE=500
# CHUNK_OVERLAP=80
# RETRIEVE_TOP_K=8
# RERANK_TOP_N=3
# HYBRID_ALPHA=0.5       # 벡터(1.0) ~ 키워드(0.0) 사이 결합 가중
# RERANK_WEIGHT=0.9      # 리랭커 신호 vs 1차 하이브리드 점수 prior 결합(0~1)
# RERANK_IDF_POWER=0.5   # 리랭커 토큰 가중 idf^p (0=균등)
# RERANK_CONTRAST_PENALTY=0.3    # 대조 섹션("~와의 차이") 페널티
# RERANK_PREAMBLE_PENALTY=0.055  # 서두 섹션("목적/개요") 감쇠
# EMBEDDER_KIND=tfidf    # tfidf | hashing | voyage
# QUERY_EXPANSION=1      # 도메인 동의어 질의 확장(부작용→이상사례). 0이면 끔

# --- 상용 임베딩(선택) ---
# EMBEDDER_KIND=voyage 로 두고 아래 키를 넣으면 실제 밀집 임베딩으로 검색합니다.
# VOYAGE_API_KEY=pa-...
